{
  "name": "opendex",
  "version": "1.3.3",
  "description": "Local bridge between OpenCode and the Opendex mobile app. Run `opendex up` to start.",
  "main": "src/index.js",
  "bin": {
    "opendex": "./bin/opendex.js",
    "remodex": "./bin/remodex.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node ./bin/opendex.js up",
    "test": "node --test ./test/*.test.js",
    "prepack": "node ./scripts/prepare-private-defaults.js",
    "postpack": "node ./scripts/cleanup-private-defaults.js"
  },
  "keywords": [
    "opendex",
    "opencode",
    "bridge",
    "cli"
  ],
  "author": "Emanuele Di Pietro",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0"
  }
}
